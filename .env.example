# Amazon SP-API credentials (LWA / Selling Partner App)
# Obtained from Seller Central → Apps & Services → Develop Apps
SP_API_REFRESH_TOKEN=Atzr|...
LWA_APP_ID=amzn1.application-oa2-client...
LWA_CLIENT_SECRET=...

# Seller ID — required for Listings tools (Seller Central → Settings → Account Info)
SP_API_SELLER_ID=...

# Default marketplace when a tool call does not specify one.
# Supported: ES, DE, FR, IT, GB, NL, BE, PL, SE, IE, US, AE, SA
SP_API_MARKETPLACE=ES
